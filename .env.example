############################
# Server（SERVER__*）
############################
SERVER__HOST=0.0.0.0
SERVER__PORT=18081
SERVER__TRANSPORT=http

# 默认 static_path = 当前工作目录 + /resources/static
# Docker 内通常是 /app/resources/static
SERVER__STATIC_PATH=/app/resources/static

SERVER__BASE_URL=/dm-mcp
SERVER__FRONTEND_URL=
SERVER__WORKERS=1

# Session secret（用于会话/安全相关；不建议写死在仓库）
SERVER__SESSION_SECRET=CHANGE_ME_SESSION_SECRET

SERVER__DEBUG=true
SERVER__AUDIT_ENABLED=true

############################
# Logging（LOGGING__*）
############################
LOGGING__LEVEL=INFO
LOGGING__LOG_DIR=/app/logs

LOGGING__ENABLE_CONSOLE=true
LOGGING__ENABLE_FILE=true
LOGGING__ENABLE_AUDIT=true

LOGGING__ROTATION="10 MB"
LOGGING__RETENTION="30 days"
LOGGING__COMPRESSION=zip

# 可选：自定义审计日志文件路径；留空则自动生成到 log_dir 下
# 不要写 LOGGING__AUDIT_FILE=（空值会被错误解析）；不需要请删除本行或整行注释掉
# LOGGING__AUDIT_FILE=/app/logs/dm_mcp_server_audit.log

############################
# Metrics（METRICS__*）
############################
METRICS__ENABLED=false
METRICS__MULTIPROC_DIR=/app/metrics
METRICS__HTTP_PORT=3001
METRICS__HTTP_PATH=/metrics

############################
# OAuth（OAUTH__*）
# OAuth 默认关闭：OAUTH__ENABLED=false
############################
OAUTH__ENABLED=false

OAUTH__GOOGLE_CLIENT_ID=
OAUTH__GOOGLE_CLIENT_SECRET=

OAUTH__MICROSOFT_CLIENT_ID=
OAUTH__MICROSOFT_CLIENT_SECRET=

OAUTH__GITHUB_CLIENT_ID=
OAUTH__GITHUB_CLIENT_SECRET=

# 自定义 provider（custom）
OAUTH__CUSTOM_PROVIDER=custom
OAUTH__CUSTOM_CLIENT_ID=
OAUTH__CUSTOM_CLIENT_SECRET=

# 发现模式（可选），如果启用 discovery，则只需设置 custom_discovery_url
OAUTH__CUSTOM_DISCOVERY_URL=

# 手动配置端点（可选）
OAUTH__CUSTOM_AUTHORIZATION_ENDPOINT=
OAUTH__CUSTOM_TOKEN_ENDPOINT=

# 辅助端点（可选）
OAUTH__CUSTOM_USERINFO_ENDPOINT=
OAUTH__CUSTOM_JWKS_URI=

############################
# Pool（POOL__*）
############################
POOL__ENABLED=true
POOL__READ_WRITE_SPLIT=true
POOL__LOAD_BALANCING_STRATEGY=least_connections

POOL__DEFAULT_SOURCE=primary
POOL__MAX_RETRIES=1
POOL__RETRY_BACKOFF_MS=100

############################
# Database（DATABASE__*）
############################
# 数据库类型：sqlite / dameng / mysql / postgresql
DATABASE__DB_TYPE=sqlite

# 通用连接参数
DATABASE__ECHO=false
DATABASE__POOL_PRE_PING=true

# SQLite
DATABASE__SQLITE__DB_PATH=/data/server.db

# # 达梦（dmAsync / dm+dmAsync）
# DATABASE__DAMENG__HOST=localhost
# DATABASE__DAMENG__PORT=5236
# DATABASE__DAMENG__USER=SYSDBA
# DATABASE__DAMENG__PASSWORD=CHANGE_ME_DM_PASSWORD
# DATABASE__DAMENG__DATABASE=

# # MySQL
# DATABASE__MYSQL__HOST=localhost
# DATABASE__MYSQL__PORT=3306
# DATABASE__MYSQL__USER=root
# DATABASE__MYSQL__PASSWORD=
# DATABASE__MYSQL__DATABASE=DMMCP
# DATABASE__MYSQL__CHARSET=utf8mb4

# # PostgreSQL
# DATABASE__POSTGRESQL__HOST=localhost
# DATABASE__POSTGRESQL__PORT=5432
# DATABASE__POSTGRESQL__USER=postgres
# DATABASE__POSTGRESQL__PASSWORD=
# DATABASE__POSTGRESQL__DATABASE=DMMCP

############################
# Token Auth（TOKEN_AUTH__*）
############################
TOKEN_AUTH__ENABLED=true
TOKEN_AUTH__CLEANUP_INTERVAL=3600
TOKEN_AUTH__AUTO_CLEANUP=true
TOKEN_AUTH__DEFAULT_EXPIRES_IN=604800

############################
# JWT（JWT__*）
############################
JWT__SECRET=CHANGE_ME_JWT_SECRET
JWT__TOKEN_EXPIRE_SECONDS=3600

