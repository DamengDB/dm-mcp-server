############################
# Server（SERVER__*）
############################
SERVER__HOST=0.0.0.0
SERVER__PORT=18081
SERVER__TRANSPORT=http

# 默认 static_path = 当前工作目录 + /resources/static
# Docker 内通常是 /app/resources/static
SERVER__STATIC_PATH=/app/resources/static

SERVER__BASE_URL=/dm-mcp
SERVER__FRONTEND_URL=
SERVER__WORKERS=1

APP_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING

SERVER__DEBUG=true
SERVER__AUDIT_ENABLED=true

############################
# Logging（LOGGING__*）
############################
LOGGING__LEVEL=INFO
LOGGING__LOG_DIR=/app/logs

LOGGING__ENABLE_CONSOLE=true
LOGGING__ENABLE_FILE=true
LOGGING__ENABLE_AUDIT=true

LOGGING__ROTATION="10 MB"
LOGGING__RETENTION="30 days"
LOGGING__COMPRESSION=zip

# 可选：自定义审计日志文件路径；留空则自动生成到 log_dir 下
# 不要写 LOGGING__AUDIT_FILE=（空值会被错误解析）；不需要请删除本行或整行注释掉
# LOGGING__AUDIT_FILE=/app/logs/dm_mcp_server_audit.log

############################
# Metrics（METRICS__*）
############################
METRICS__ENABLED=false
METRICS__MULTIPROC_DIR=/app/metrics
METRICS__HTTP_PORT=3001
METRICS__HTTP_PATH=/metrics

############################
# OAuth（OAUTH__*）
# OAuth provider 配置已迁移到数据库，env 仅保留加密主密钥
############################

############################
# Database（DATABASE__*）
############################
# 数据库类型：sqlite / dameng / mysql / postgresql
DATABASE__DB_TYPE=sqlite

# 通用连接参数
DATABASE__ECHO=false
DATABASE__POOL_PRE_PING=true

# SQLite
DATABASE__SQLITE__DB_PATH=/data/server.db

# # 达梦（dmAsync / dm+dmAsync）
# DATABASE__DAMENG__HOST=localhost
# DATABASE__DAMENG__PORT=5236
# DATABASE__DAMENG__USER=SYSDBA
# DATABASE__DAMENG__PASSWORD=CHANGE_ME_DM_PASSWORD
# DATABASE__DAMENG__DATABASE=

